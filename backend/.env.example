# ═══════════════════════════════════════════════════════
#  WasselERP Enterprise — Backend Environment Variables
# ═══════════════════════════════════════════════════════

# Server
NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/wassel_erp?retryWrites=true&w=majority

# JWT — use strong random string (min 64 chars)
JWT_SECRET=change-this-to-a-very-long-random-string-minimum-64-characters-required
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (for CORS + password reset links)
FRONTEND_URL=http://localhost:3000

# Admin setup secret (first-time superadmin creation)
ADMIN_SECRET=change-this-admin-secret

# Email (Nodemailer — Gmail App Password or SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password-16-chars
EMAIL_FROM_NAME=WasselERP
EMAIL_FROM_ADDR=noreply@wasserp.com

# File Uploads (Cloudinary — optional, uses local if not set)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redis (optional — for caching & sessions)
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Logging
LOG_LEVEL=info
